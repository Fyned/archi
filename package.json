{
  "name": "archi-construction-veranda",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "skipThirdPartyRequests": true,
    "asyncScriptTags": true,
    "minifyHtml": {
      "collapseWhitespace": true,
      "removeComments": true
    },
    "include": [
      "/",
      "/fr/", "/fr/about/", "/fr/services/", "/fr/services/pergola/", "/fr/services/veranda/", "/fr/services/carport/", "/fr/services/window/", "/fr/services/shutter/", "/fr/services/garage/",
      "/fr/contact/", "/fr/quote/", "/fr/blog/", "/fr/projects/", "/fr/portfolio/", "/fr/privacy/", "/fr/videos/", "/fr/marketplace/",
      "/fr/blog/pergola-bioclimatique-guide-complet/", "/fr/blog/veranda-aluminium-vs-pvc/", "/fr/blog/carport-solaire-belgique/",
      "/fr/blog/entretien-pergola-aluminium/", "/fr/blog/permis-urbanisme-belgique/", "/fr/blog/tendances-outdoor-2026/",
      "/fr/blog/pergola-bioclimatique-charleroi/", "/fr/blog/veranda-aluminium-bruxelles/", "/fr/blog/carport-aluminium-namur/", "/fr/blog/pergola-prix-m2-belgique-2026/",
      "/nl/", "/nl/about/", "/nl/services/", "/nl/services/pergola/", "/nl/services/veranda/", "/nl/services/carport/", "/nl/services/window/", "/nl/services/shutter/", "/nl/services/garage/",
      "/nl/contact/", "/nl/quote/", "/nl/blog/", "/nl/projects/", "/nl/portfolio/", "/nl/privacy/", "/nl/videos/", "/nl/marketplace/",
      "/en/", "/en/about/", "/en/services/", "/en/services/pergola/", "/en/services/veranda/", "/en/services/carport/", "/en/services/window/", "/en/services/shutter/", "/en/services/garage/",
      "/en/contact/", "/en/quote/", "/en/blog/", "/en/projects/", "/en/portfolio/", "/en/privacy/",
      "/de/", "/de/about/", "/de/services/", "/de/services/pergola/", "/de/services/veranda/", "/de/services/carport/", "/de/services/window/", "/de/services/shutter/", "/de/services/garage/",
      "/de/contact/", "/de/quote/", "/de/blog/", "/de/projects/", "/de/portfolio/", "/de/privacy/",
      "/tr/", "/tr/about/", "/tr/services/", "/tr/services/pergola/", "/tr/services/veranda/", "/tr/services/carport/", "/tr/services/window/", "/tr/services/shutter/", "/tr/services/garage/",
      "/tr/contact/", "/tr/quote/", "/tr/blog/", "/tr/projects/", "/tr/portfolio/", "/tr/privacy/"
    ]
  },
  "dependencies": {
    "@sanity/client": "^6.15.0",
    "@sanity/image-url": "^1.0.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.25.0",
    "i18next": "^23.11.0",
    "i18next-browser-languagedetector": "^7.2.1",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-facebook": "^10.0.1",
    "react-helmet-async": "^2.0.4",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^6.23.0"
